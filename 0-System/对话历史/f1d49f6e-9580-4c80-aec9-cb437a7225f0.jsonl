getCloudflaredInstallHint());\n   101→    process.exit(1);\n   102→  }\n   103→  console.log(chalk.green(\"✓ cloudflared 可用\\n\"));\n   104→\n   105→  // 解析工作目录\n   106→  const cwdIndex = args.indexOf(\"--cwd\");\n   107→  let cwd: string;\n   108→\n   109→  if (cwdIndex !== -1 && args[cwdIndex + 1]) {\n   110→    // 用户显式指定了 --cwd\n   111→    cwd = args[cwdIndex + 1];\n   112→  } else {\n   113→    // 自动检测：从当前目录向上查找项目根目录\n   114→    const detected = findProjectRoot(process.cwd());\n   115→    if (detected) {\n   116→      cwd = detected;\n   117→      if (detected !== process.cwd()) {\n   118→        console.log(chalk.cyan(`自动检测到项目根目录: ${detected}`));\n   119→      }\n   120→    } else {\n   121→      // 没找到，使用当前目录，但给出警告\n   122→      cwd = process.cwd();\n   123→      console.log(chalk.yellow(\"⚠️  未检测到 .claude/ 或 CLAUDE.md，使用当前目录\"));\n   124→      console.log(chalk.yellow(\"   如果 hooks 不生效，请用 --cwd 指定项目根目录\\n\"));\n   125→    }\n   126→  }\n   127→  console.log(`工作目录: ${cwd}\\n`);\n   128→\n   129→  // 检查是否需要重置\n   130→  const resetFlag = args.includes(\"--reset\");\n   131→  if (resetFlag) {\n   132→    deleteConfig(cwd);\n   133→  }\n   134→\n   135→  // 加载或创建设备配置\n   136→  let config = loadConfig(cwd);\n   137→  let isFirstRun = false;\n   138→\n   139→  if (config) {\n   140→    console.log(chalk.green(\"✓ 已加载设备配置\"));\n   141→    console.log(chalk.gray(`  设备 ID: ${config.deviceId}`));\n   142→    console.log(chalk.gray(`  配对码: ${config.pairCode}`));\n   143→    if (config.routeToken) {\n   144→      console.log(chalk.gray(`  连接码: ${config.routeToken}\\n`));\n   145→    }\n   146→  } else {\n   147→    // 首次运行，生成新配置\n   148→    isFirstRun = true;\n   149→    config = {\n   150→      deviceId: generateDeviceId(),\n   151→      pairCode: generateCode(),\n   152→      createdAt: new Date().toISOString()\n   153→    };\n   154→    console.log(chalk.yellow(\"首次运行，生成新设备配置\"));\n   155→    console.log(chalk.gray(`  设备 ID: ${config.deviceId}`));\n   156→    console.l